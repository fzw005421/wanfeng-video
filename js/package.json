{
  "name": "wanfeng-video",
  "version": "1.0.0",
  "description": "晚风影视 - Windows桌面客户端",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.wanfeng.video",
    "productName": "晚风影视",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "extraFiles": [
      {
        "from": "ffmpeg/ffmpeg.dll",
        "to": "ffmpeg.dll"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "晚风影视",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "hls.js": "^1.5.17"
  }
}
